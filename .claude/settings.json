{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cargo test || exit 2"
          },
          {
            "type": "command",
            "command": "cargo fmt || exit 2"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo build)"
    ]
  }
}