# Tracing configuration examples

# Set global log level
RUST_LOG=info

# Set specific module log levels
# RUST_LOG=ganbot3=debug

# Multiple module configurations
# RUST_LOG=ganbot3=trace,irc=warn,kameo=info

# Enable all debug logging
# RUST_LOG=debug

# Disable most logging except errors
# RUST_LOG=error

# Complex filter with specific targets
# RUST_LOG=ganbot3::network=trace,ganbot3::actors=debug,warn